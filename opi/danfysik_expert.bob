<?xml version="1.0" encoding="UTF-8"?>
<!--Saved on 2026-01-09 12:00:00 by user-->
<display version="2.0.0">
  <name>Danfysik Expert Panel</name>
  <macros>
    <DEVICE>BTF:MAG:DANFYSIK:QUATM002</DEVICE>
  </macros>
  <width>1000</width>
  <height>1010</height>
  <background_color>
    <color name="Display_Background" red="255" green="255" blue="255">
    </color>
  </background_color>
  
  <!-- Title -->
  <widget type="label" version="2.0.0">
    <name>Title</name>
    <text>Danfysik SYS8X00 - Expert/Debug Panel</text>
    <x>20</x>
    <y>10</y>
    <width>400</width>
    <height>30</height>
    <font>
      <font name="Header 1" family="Liberation Sans" style="BOLD" size="18.0">
      </font>
    </font>
    <foreground_color>
      <color name="STOP" red="255" green="0" blue="0">
      </color>
    </foreground_color>
  </widget>
  
  <!-- Warning -->
  <widget type="label" version="2.0.0">
    <name>Warning</name>
    <text>⚠️ EXPERT MODE - Use with caution! Direct hardware control.</text>
    <x>20</x>
    <y>45</y>
    <width>600</width>
    <height>20</height>
    <font>
      <font name="Default Bold" family="Liberation Sans" style="BOLD" size="12.0">
      </font>
    </font>
    <foreground_color>
      <color name="MAJOR" red="255" green="0" blue="0">
      </color>
    </foreground_color>
  </widget>
  
  <!-- Direct Hardware Control Section -->
  <widget type="rectangle" version="2.0.0">
    <name>HardwareFrame</name>
    <x>20</x>
    <y>80</y>
    <width>960</width>
    <height>150</height>
    <line_color>
      <color name="MAJOR" red="255" green="0" blue="0">
      </color>
    </line_color>
    <background_color>
      <color name="Write_Background" red="255" green="240" blue="240">
      </color>
    </background_color>
  </widget>
  
  <widget type="label" version="2.0.0">
    <name>HardwareTitle</name>
    <text>Direct Hardware Control</text>
    <x>30</x>
    <y>90</y>
    <width>200</width>
    <height>20</height>
    <font>
      <font name="Header 2" family="Liberation Sans" style="BOLD" size="14.0">
      </font>
    </font>
  </widget>
  
  <!-- Direct Current Control -->
  <widget type="label" version="2.0.0">
    <name>DirectCurrentLabel</name>
    <text>Direct Current (DAC):</text>
    <x>30</x>
    <y>120</y>
    <width>130</width>
    <height>20</height>
  </widget>
  
  <widget type="textentry" version="3.0.0">
    <name>DirectCurrent</name>
    <pv_name>$(P):$(R):I_SP</pv_name>
    <x>160</x>
    <y>120</y>
    <width>120</width>
    <height>20</height>
    <precision>3</precision>
    <background_color>
      <color name="Write_Background" red="255" green="240" blue="240">
      </color>
    </background_color>
  </widget>
  
  <widget type="label" version="2.0.0">
    <name>DirectCurrentSPRB</name>
    <text>SP RB:</text>
    <x>290</x>
    <y>120</y>
    <width>40</width>
    <height>20</height>
  </widget>
  
  <widget type="textupdate" version="2.0.0">
    <name>DirectCurrentReadback</name>
    <pv_name>$(P):$(R):I_SP_RB</pv_name>
    <x>330</x>
    <y>120</y>
    <width>100</width>
    <height>20</height>
    <precision>3</precision>
    <background_color>
      <color name="Read_Background" red="240" green="240" blue="240">
      </color>
    </background_color>
  </widget>
  
  <!-- Address Control -->
  <widget type="label" version="2.0.0">
    <name>AddressSetLabel</name>
    <text>Set Address:</text>
    <x>450</x>
    <y>120</y>
    <width>80</width>
    <height>20</height>
  </widget>
  
  <widget type="textentry" version="3.0.0">
    <name>AddressSet</name>
    <pv_name>$(P):$(R):ADDR_SP</pv_name>
    <x>530</x>
    <y>120</y>
    <width>60</width>
    <height>20</height>
    <background_color>
      <color name="Write_Background" red="255" green="240" blue="240">
      </color>
    </background_color>
  </widget>
  
  <!-- Communication Test -->
  <widget type="action_button" version="3.0.0">
    <name>InitRemoteButton</name>
    <actions>
      <action type="write_pv">
        <pv_name>$(P):$(R):INIT_REMOTE</pv_name>
        <value>1</value>
        <description>Initialize Remote Control</description>
      </action>
    </actions>
    <text>INIT REMOTE</text>
    <x>620</x>
    <y>120</y>
    <width>100</width>
    <height>25</height>
    <background_color>
      <color name="Button_Background" red="210" green="210" blue="210">
      </color>
    </background_color>
  </widget>
  
  <widget type="action_button" version="3.0.0">
    <name>ErrorTextButton</name>
    <actions>
      <action type="write_pv">
        <pv_name>$(P):$(R):ERROR_TEXT</pv_name>
        <value>1</value>
        <description>Enable Text Error Messages</description>
      </action>
    </actions>
    <text>ERROR TEXT</text>
    <x>730</x>
    <y>120</y>
    <width>100</width>
    <height>25</height>
    <background_color>
      <color name="Button_Background" red="210" green="210" blue="210">
      </color>
    </background_color>
  </widget>
  
  <!-- Advanced Ramping -->
  <widget type="label" version="2.0.0">
