      <action type="open_display">
        <file>danfysik_unimag.bob</file>
        <macros>
          <DEVICE>$(DEVICE)</DEVICE>
        </macros>
        <target>tab</target>
        <description>Open UNIMAG Interface</description>
      </action>
    </actions>
    <text>UNIMAG Panel</text>
    <x>150</x>
    <y>640</y>
    <width>120</width>
    <height>30</height>
    <background_color>
      <color name="Button_Background" red="210" green="210" blue="210">
      </color>
    </background_color>
  </widget>
  
