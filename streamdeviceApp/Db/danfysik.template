################################################################################
# Status Monitoring
################################################################################

record(stringin, "$(DEVICE):STATUS")
{
    field(DESC, "Status String")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_status($(ADDR)) $(PORT)")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

# Same S1 status string decoded as a 24-bit mask (character 1 = bit 23 ...
# character 24 = bit 0), per the manual's per-character bit table:
# bit23=MAIN POWER OFF, bit21=POL NORMAL, bit20=POL REVERSED,
# bit14=SUM-INTERLOCK, bit13=DC OVERCURRENT, bit11=REG MODULE FAILURE,
# bit10=PREREGULATOR FAILURE, bit9=PHASE FAILURE, bit8=WATERFLOW FAILURE.
record(mbbiDirect, "$(DEVICE):STATUS_BITS")
{
    field(DESC, "Status Bitmask")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_status_bits($(ADDR)) $(PORT)")
    field(NOBT, "24")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

# STATUS_BITS.B<n> (mbbiDirect) exposes each bit individually for OPI LEDs,
# e.g. STATUS_BITS.B13 = DC OVERCURRENT, without extra polling of S1:
# B23=MAIN POWER OFF, B21=POL NORMAL, B20=POL REVERSED, B16=SPARE INTERLOCK,
# B15=ONE TRANSISTOR FAULT, B14=SUM-INTERLOCK, B13=DC OVERCURRENT,
# B12=DC OVERLOAD, B11=REGULATION MODULE FAILURE, B10=PREREGULATOR FAILURE,
# B9=PHASE FAILURE, B8=MPS WATERFLOW FAILURE, B7=EARTH LEAKAGE FAILURE,
# B6=THERMAL BREAKER/FUSES, B5=MPS OVERTEMPERATURE, B4=PANIC BUTTON/DOOR
# SWITCH, B3=MAGNET WATERFLOW FAILURE, B2=MAGNET OVERTEMPERATURE,
# B1=MPS NOT READY.

# Individual status bits (derived from the real status bitmask)
record(calc, "$(DEVICE):MAIN_PWR_ON")
{
    field(DESC, "Main Power ON")
    # bit23 = "MAIN POWER OFF"; ON when that bit is clear
    field(CALC, "!((A>>23)&1)")
    field(INPA, "$(DEVICE):STATUS_BITS")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

record(calc, "$(DEVICE):POL_NORMAL")
{
    field(DESC, "Polarity Normal")
    field(CALC, "A>0")  # Simplified check
    field(INPA, "$(DEVICE):POL_RB.SEVR")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

record(calc, "$(DEVICE):POL_REVERSED")
{
    field(DESC, "Polarity Reversed")
    field(CALC, "!A")  # Simplified check
    field(INPA, "$(DEVICE):POL_NORMAL")  
    field(SCAN, "$(SCAN_FAST=1 second)")
}

