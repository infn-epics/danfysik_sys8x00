################################################################################

record(calc, "$(DEVICE):CONNECTED")
{
    field(DESC, "Connection Status")
    # I_RB.STAT is 0 (NO_ALARM) exactly when the last comms read succeeded
    field(CALC, "A=0")
    field(INPA, "$(DEVICE):I_RB.STAT")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

################################################################################
# Raw ADC Diagnostics (unscaled - no IMAX/VMAX conversion applied)
################################################################################
# Plain "AD n" replies, straight from the device, with no ASLO/ESLO applied.
# Useful to calibrate/verify IMAX and VMAX against known real readings
# without a wrong nominal-current guess distorting the numbers.

record(longin, "$(DEVICE):RAW_AD0")
{
    # Actually ADCV (18-bit ADC, raw mA) now, not literally "AD 0" - kept
    # this PV name for compatibility. See get_actual_current comment in
    # danfysik.proto for why "AD 0" itself was wrong on this unit.
    field(DESC, "Raw ADCV - Output Current (mA)")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_actual_current($(ADDR)) $(PORT)")
    field(SCAN, "$(SCAN_SLOW=10 second)")
}

