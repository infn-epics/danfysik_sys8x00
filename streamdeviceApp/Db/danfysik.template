record(bo, "$(DEVICE):REMOTE")
{
    field(DESC, "Remote Control")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto remote_ctrl($(ADDR)) $(PORT)")
    field(ZNAM, "Local")
    field(ONAM, "Remote")
    field(VAL,  "1")
    # No longer PINI="YES" - don't force remote mode automatically at every
    # IOC boot, only when explicitly commanded.
}

record(bo, "$(DEVICE):RLOCK")
{
    field(DESC, "Remote Lock")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto remote_lock($(ADDR)) $(PORT)")
    field(ZNAM, "Unlocked")
    field(ONAM, "Locked")
}

record(bo, "$(DEVICE):UNLOCK")
{
    # Releases a LOCK condition set by the local control panel so the
    # remote line can hold control. Manual: emergency use only. CTRL_STATE
    # (CMDSTATE) reading "LOCK" instead of "REMOTE" despite CMD saying REM
    # is the leading theory for why a remote power-on doesn't hold.
    field(DESC, "Unlock Remote Control")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto unlock($(ADDR)) $(PORT)")
    field(ZNAM, "Unlock")
    field(ONAM, "Unlock")
    field(VAL,  "0")
}

################################################################################
# Current Control (Main)
################################################################################

record(ao, "$(DEVICE):I_SP")
{
    field(DESC, "Current Setpoint")
    # No longer writes "WA" directly to hardware. setCurrent&TrigSYS8X00.vi
    # (the working LabVIEW software) always sets current via WAR (ramp
    # end) + TS (trigger), never WA - so this now just forwards to
    # RAMP_END_SP, which does the real WAR write and FLNKs to
    # SEQ_TRIGGER (TS), matching that pattern exactly.
    field(DTYP, "Soft Channel")
    field(OUT,  "$(DEVICE):RAMP_END_SP PP")
    field(EGU,  "A")
    field(PREC, "$(PREC=3)")
    # Hardware floor: the device's WAR command rejects end-current values
    # <= 1000 raw DAC units (manual: "must be > 1000 mA"), which at this
    # unit's confirmed DAC/1000 = Amps scaling is 1 A - a true 0 A
    # setpoint is silently unreachable via WAR/TS. Use F/GOFF to actually
    # reach zero.
    field(DRVL, "1")
    field(DRVH, "$(IMAX)")
    field(HOPR, "$(IMAX)")
    field(LOPR, "1")
}

record(longout, "$(DEVICE):RAW_WA")
{
    field(DESC, "Raw DAC Setpoint (direct write, no IMAX scaling)")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto set_current($(ADDR)) $(PORT)")
    field(DRVL, "0")
    field(DRVH, "999999")
}

record(ai, "$(DEVICE):I_SP_RB")
{
    field(DESC, "Current Setpoint Readback")  
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_current_sp($(ADDR)) $(PORT)")
    field(EGU,  "A")
    field(PREC, "$(PREC=3)")
    field(SCAN, "$(SCAN_FAST=1 second)")
    field(HOPR, "$(IMAX)")
    field(LOPR, "0")
    # Convert DAC value to Amps. The manual's generic formula
    # (Current = Nominal_Current * DAC/1e6, i.e. scaled by IMAX) does NOT
    # match this unit's real behavior. So this is a fixed conversion, not
    # IMAX-dependent - IMAX only limits DRVH/HOPR (a configurable safety
    # ceiling), not the physical scaling.
    # Fixed scale is DAC/1000, not DAC/10000 - the earlier /10000 figure
    # was off by 10x (confirmed against real hardware: setpoint raw 99998
    # with actual output measured at 100A -> 99998/1000 = 99.998, matching;
    # 99998/10000 = 9.9998 does NOT, which is exactly the "IOC shows 10,
    # real output is 100" symptom that exposed the bug).
    field(ASLO, "1")
    field(AOFF, "0")
    field(LINR, "SLOPE")
    field(ESLO, "0.001")
    field(EOFF, "0")
}

record(ai, "$(DEVICE):I_RB")
{
    field(DESC, "Output Current Readback")
    field(DTYP, "stream")
    # ADCV (18-bit ADC), not "AD 0" - this unit's own AD-channel table
    # (manual p.33) has "AD 0" = R ac (mains) voltage, not output current,
    # which is why this always read a near-constant ~260 regardless of
    # setpoint. ADCV returns actual output current directly in mA.
    field(INP,  "@danfysik.proto get_actual_current($(ADDR)) $(PORT)")
    field(EGU,  "A")
    field(PREC, "$(PREC=3)")
    field(SCAN, "$(SCAN_FAST=1 second)")
    field(HOPR, "$(IMAX)")
    field(LOPR, "0")
    # ADCV's raw reading uses the same fixed 1/1000 scale as RA/WAR (see
    # I_SP_RB above) - confirmed against real hardware: raw 99894 with
    # actual output measured at ~100A -> 99894/1000 = 99.894, matching.
    # The earlier /10000 figure was off by 10x (gave ~10 instead of ~100).
    field(ASLO, "1")
    field(AOFF, "0")
    field(LINR, "SLOPE")
    field(ESLO, "0.001")
    field(EOFF, "0")
}

# High resolution current reading (if available)
record(ai, "$(DEVICE):I_HIRES_RB")
{
    field(DESC, "High-Res Current Readback")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_hires_current($(ADDR)) $(PORT)")
    field(EGU,  "A")
    field(PREC, "5")
    field(SCAN, "$(SCAN_FAST=1 second)")
    field(HOPR, "$(IMAX)")
    field(LOPR, "0")
    # Convert high-res percentage to Amps: I = Imax * (reading/100000)
    field(ASLO, "$(IMAX)")
    field(AOFF, "0")
    field(LINR, "SLOPE")
    field(ESLO, "0.00001") 
    field(EOFF, "0")
}

################################################################################
# Voltage Monitoring
################################################################################

record(ai, "$(DEVICE):V_RB")
{
    field(DESC, "Output Voltage Readback")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_output_voltage($(ADDR)) $(PORT)")
    field(EGU,  "V")
    field(PREC, "$(PREC=3)")
    field(SCAN, "$(SCAN_FAST=1 second)")
    field(HOPR, "$(VMAX)")
    field(LOPR, "0")
    # Channel 6 ("Output voltage") format per this unit's real AD table
    # (manual p.33) is plain "DDD" - direct volts, not a (V/Vn)*100
    # percentage. Confirmed empirically: raw=1 while I_RB read ~3A,
    # matching a plausible 1V drop directly, not 1% of VMAX(25)=0.25V
    # (the old, wrong scaling). No VMAX involved - direct 1:1 reading.
    field(ASLO, "1")
    field(AOFF, "0")
    field(LINR, "SLOPE")
    field(ESLO, "1")
    field(EOFF, "0")
}

################################################################################
# Ramping Control
################################################################################

record(ao, "$(DEVICE):RAMP_END_SP")
{
    field(DESC, "Ramp End Current")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto set_ramp_end($(ADDR)) $(PORT)")
    field(EGU,  "A")
    field(PREC, "$(PREC=3)")
    # Hardware floor: WAR rejects end-current <= 1000 raw DAC units
    # (manual: "must be > 1000 mA"), i.e. 1 A at this unit's confirmed
    # DAC/1000 = Amps scaling - see I_SP_RB for details. DRVL clamps
    # writes here instead of silently sending an unreachable WAR 000000.
    field(DRVL, "1")
    field(DRVH, "$(IMAX)")
    field(HOPR, "$(IMAX)")
    field(LOPR, "1")
    # Fixed DAC<->Amps conversion (DAC/1000), not IMAX-dependent - see
    # the comment on I_SP_RB above for why. IMAX only limits DRVH/HOPR.
    field(ASLO, "1")
    field(AOFF, "0")
    field(LINR, "SLOPE")
    field(ESLO, "0.001")
    field(EOFF, "0")
    # setCurrent&TrigSYS8X00.vi (the working LabVIEW software) always
    # follows WAR with TS (trigger sequence) rather than using WA
    # directly - so writing here also fires the trigger, same as LabVIEW.
    field(FLNK, "$(DEVICE):SEQ_TRIGGER PP")
}

record(ai, "$(DEVICE):RAMP_END_RB")
{
    field(DESC, "Ramp End Readback")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_ramp_end($(ADDR)) $(PORT)")
    field(EGU,  "A")
    field(PREC, "$(PREC=3)")
    field(SCAN, "$(SCAN_FAST=1 second)")
    field(HOPR, "$(IMAX)")
    field(LOPR, "0")
    # Fixed DAC<->Amps conversion (DAC/1000), not IMAX-dependent - see
    # the comment on I_SP_RB above for why.
    field(ASLO, "1")
    field(AOFF, "0")
    field(LINR, "SLOPE")
    field(ESLO, "0.001")
    field(EOFF, "0")
}

record(ao, "$(DEVICE):RAMP_RATE_SP")
{
    field(DESC, "Ramp Rate")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto set_ramp_speed($(ADDR)) $(PORT)")
    field(EGU,  "A/s")
    field(PREC, "$(PREC=3)")
    field(DRVL, "0")
    field(DRVH, "$(IMAX)")
    field(HOPR, "$(IMAX)")
    field(LOPR, "0")
    field(VAL,  "5.0")
    # Protocol expects raw 001-100, representing 0.1%-10% of IMAX per
    # second. Same ASLO/ESLO pattern as RAMP_RATE_RB (its mirror-image
    # readback, which was already correct) - the old ASLO=10/ESLO=100
    # computed RVAL = VAL/(ASLO*ESLO) = VAL/1000, which rounds to 0 for
    # any VAL below 1000 A/s, silently never reaching hardware (WR was
    # never actually sent with a nonzero rate - confirmed via
    # RAMP_RATE_RB/RVAL reading back 0 after setting VAL=5).
    field(ASLO, "$(IMAX)")
    field(AOFF, "0")
    field(LINR, "SLOPE")
    field(ESLO, "0.001")
    field(EOFF, "0")
}

record(ai, "$(DEVICE):RAMP_RATE_RB")
{
    field(DESC, "Ramp Rate Readback")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_ramp_speed($(ADDR)) $(PORT)")
    field(EGU,  "A/s")
    field(PREC, "$(PREC=3)")
    field(SCAN, "$(SCAN_FAST=1 second)")
    field(HOPR, "$(IMAX)")
    field(LOPR, "0")
    # Convert protocol value to A/s
    field(ASLO, "$(IMAX)")
    field(AOFF, "0")
    field(LINR, "SLOPE")
    field(ESLO, "0.001")
    field(EOFF, "0")
}

