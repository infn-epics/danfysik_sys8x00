    field(PREC, "2")
    field(SCAN, "$(SCAN_FAST=1 second)")
    # Convert from T*100 to T
    field(ASLO, "0.01")
    field(AOFF, "0")
}

################################################################################
# Communication Control
################################################################################

record(bo, "$(DEVICE):INIT_REMOTE")
{
    field(DESC, "Initialize Remote Control")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto init_remote($(ADDR)) $(PORT)")
    field(ZNAM, "Initialize")
    field(ONAM, "Initialize")
    field(VAL,  "0")
    # No longer PINI="YES" - this also sends "RS" (reset interlocks), so it
    # must only run when explicitly commanded, never silently at every boot.
}

record(bo, "$(DEVICE):ERROR_TEXT")
{
    field(DESC, "Enable Text Error Messages")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto error_text($(ADDR)) $(PORT)")
    field(ZNAM, "Enable")
    field(ONAM, "Enable")
    field(VAL,  "0")
    # No longer PINI="YES" - only run when explicitly commanded.
}

record(bo, "$(DEVICE):ERROR_CODE")
{
    # ERRC (coded errors) - what initializeSYS8X00.vi (the working
    # LabVIEW control software) actually uses, not ERRT.
    field(DESC, "Enable Coded Error Messages")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto error_code($(ADDR)) $(PORT)")
    field(ZNAM, "Enable")
    field(ONAM, "Enable")
    field(VAL,  "0")
}

record(bo, "$(DEVICE):NO_ANSWER")
{
    # NASW - cancel auto-answer mode. initializeSYS8X00.vi always sends
    # this; if ASW was left on from an earlier session, WA/PO+/PO-/
    # W1-W3 generate unsolicited replies our protocol doesn't expect,
    # which could desync subsequent reads.
    field(DESC, "Cancel Auto-Answer Mode")
    field(DTYP, "stream")
    field(OUT,  "@danfysik.proto no_answer($(ADDR)) $(PORT)")
    field(ZNAM, "Disable")
    field(ONAM, "Disable")
    field(VAL,  "0")
}

