    field(EGU,  "A/s")
    field(PREC, "$(PREC=3)")
    field(SCAN, "$(SCAN_FAST=1 second)")
    field(HOPR, "$(IMAX)")
    field(LOPR, "0")
    # Convert protocol value to A/s
    field(ASLO, "$(IMAX)")
    field(AOFF, "0")
    field(LINR, "SLOPE")
    field(ESLO, "0.001")
    field(EOFF, "0")
}

