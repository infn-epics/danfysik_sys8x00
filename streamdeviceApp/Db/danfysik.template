################################################################################
# Status Monitoring
################################################################################

record(stringin, "$(DEVICE):STATUS")
{
    field(DESC, "Status String")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_status($(ADDR)) $(PORT)")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

# Same S1 status string decoded as a bit mask. The real reply is 32
# characters (confirmed via streamDebug trace 2026-07-10) - the generic
# 24-char command reference does NOT match this unit at all. The correct,
# model-specific table is in "Danfysik-manuale sys 8800 (QUA-SXP).pdf"
# (MAGNET POWER SUPPLY SYSTEM 8800, ITA 4546/INFN Frascati), p.54,
# char 0 = first character .. char 31 = last (so bit = 31 - char):
#
# char  bit  type       meaning
#  0    31   Spare
#  1    30   Interlock  User interlock 1
#  2    29   Interlock  User interlock 2
#  3    28   Interlock  User interlock 3
#  4    27   Interlock  User interlock 4
#  5    26   Interlock  User interlock 5
#  6    25   Interlock  User interlock 6
#  7    24   Interlock  Freewheel diode overtemp
#  8    23   Interlock  Low water flow
#  9    22   Interlock  Door open
# 10    21   Status     Positive polarity
# 11    20   Status     Negative polarity
# 12    19   Spare
# 13    18   Spare
# 14    17   Spare
# 15    16   Spare
# 16    15   Interlock  Diode heatsink overtemp
# 17    14   Interlock  Chassis overtemp
# 18    13   Interlock  IGBT heatsink overtemp
# 19    12   Interlock  H.F. diode overtemp
# 20    11   Interlock  Switch reg. DCCT failure
# 21    10   Interlock  Switch regulator supply failure
# 22     9   Interlock  IGBT driver failure
# 23     8   Spare
# 24     7   Spare
# 25     6   Warning    AC undervoltage
# 26     5   Spare
# 27     4   Warning    Excessive current ripple
# 28     3   Warning    Ground leak current
# 29     2   Interlock  Overcurrent
# 30     1   Status     Main power is on
# 31     0   Status     Ready
#
# Verified empirically 2026-07-10: bit1 (char30) is the only bit that
# changed when POWER_SP was toggled on a live unit, and it read "." while
# genuinely on and "!" while off - i.e. this table's "!" means the same
# "abnormal/flagged" as every other manual (INTERLOCK: tripped; for this
# STATUS row: NOT on). Also confirmed: in both units' baseline readings,
# zero "Interlock"-type bits were active - matching direct physical
# confirmation that there was no real interlock present. The bits
# previously treated as faults (old positions 11-16) are actually
# Spare/Polarity-status bits (char 10-15) on this unit, which is exactly
# why they never reacted to anything real.
record(mbbiDirect, "$(DEVICE):STATUS_BITS")
{
    field(DESC, "Status Bitmask")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto get_status_bits($(ADDR)) $(PORT)")
    field(NOBT, "32")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

# Individual status bits (derived from the real status bitmask)
record(calc, "$(DEVICE):MAIN_PWR_ON")
{
    field(DESC, "Main Power ON")
    # bit1 (char30) = "Main power is on"; empirically "." while genuinely
    # on, "!" while off (see STATUS_BITS comment above).
    field(CALC, "!((A>>1)&1)")
    field(INPA, "$(DEVICE):STATUS_BITS")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

################################################################################
# Quick Binary Reads (?2/?3) - for catching fast transients the normal
# 1-second S1/AD polling can miss (e.g. a power-on that trips back off
# within a second or two).
################################################################################

record(longin, "$(DEVICE):QUICK_STATUS_RAW")
{
    field(DESC, "Quick Binary Status (?2), 32-bit raw")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto quick_status_bin($(ADDR)) $(PORT)")
    field(SCAN, "$(SCAN_SLOW=10 second)")
}

record(waveform, "$(DEVICE):QUICK_COMBINED_RAW")
{
    field(DESC, "Quick Combined Status+Current (?3), 4+3 raw bytes")
    field(DTYP, "stream")
    field(INP,  "@danfysik.proto quick_combined_bin($(ADDR)) $(PORT)")
    field(FTVL, "UCHAR")
    field(NELM, "7")
    field(SCAN, "$(SCAN_SLOW=10 second)")
}

record(bi, "$(DEVICE):POL_NORMAL")
{
    field(DESC, "Polarity Normal")
    field(DTYP, "stream")
    # Real "PO" reading ("+"=Normal), not POL_RB.SEVR (comms-health, not
    # actual polarity - was always wrong regardless of real polarity,
    # which made the UNIMAG sequencer always think a polarity change was
    # needed and autonomously ramp back to standby/off after any
    # CURRENT_SP write).
    field(INP,  "@danfysik.proto get_polarity_normal($(ADDR)) $(PORT)")
    field(ZNAM, "Reversed/Other")
    field(ONAM, "Normal")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

record(calc, "$(DEVICE):POL_REVERSED")
{
    field(DESC, "Polarity Reversed")
    field(CALC, "!A")
    field(INPA, "$(DEVICE):POL_NORMAL")
    field(SCAN, "$(SCAN_FAST=1 second)")
}

