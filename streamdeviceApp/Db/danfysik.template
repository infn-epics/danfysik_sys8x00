    field(ZNAM, "Off")
    field(ONAM, "On")
    field(HIGH, "1")
    # Process OFF record when this goes to 0
    field(FLNK, "$(DEVICE):POWER_OFF_PROC")
}

# Helper record to handle power off
record(calcout, "$(DEVICE):POWER_OFF_PROC")
